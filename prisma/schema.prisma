generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BillingType {
  TJM
  FORFAIT
  MISSION
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  CANCELED
  PAST_DUE
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  name                String?
  avatarUrl           String?

  // Profil freelance
  monthlyExpenses     Float              @default(1800)
  savings             Float              @default(10000)
  adminHoursPerWeek   Float              @default(6)
  workDaysPerWeek     Int                @default(5)
  workedDaysPerYear   Int?
  businessStatus      String             @default("micro")
  remunerationType    String?
  customUrssafRate    Float?
  customIrRate        Float?
  customTaxRate       Float?
  monthlySalary       Float              @default(0)
  mixtePartSalaire    Float              @default(50)
  role                String?
  age                 Int                @default(35)
  vacationDaysPerMonth Json?
  onboardingCompleted Boolean            @default(false)

  // Facturation
  companyName         String?
  siret               String?
  tvaNumber           String?
  invoiceAddress      String?
  invoiceCity         String?
  invoiceZip          String?
  iban                String?
  bic                 String?
  invoiceNotes        String?

  // Stripe
  stripeCustomerId    String?            @unique
  subscriptionStatus  SubscriptionStatus @default(FREE)
  subscriptionId      String?
  trialEndsAt         DateTime?

  // Relations
  clients             Client[]
  scenarios           Scenario[]
  payments            Payment[]
  snapshots           MonthlySnapshot[]
  prospects           Prospect[]
  holdingStructure    HoldingStructure?
  documents           Document[]

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Client {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  billing        BillingType

  // TJM
  dailyRate      Float?
  daysPerMonth   Float?
  daysPerWeek    Float?
  daysPerYear    Float?

  // Forfait
  monthlyAmount  Float?

  // Mission
  totalAmount    Float?
  startMonth     Int?
  endMonth       Int?

  // Contact / facturation
  email          String?
  companyName    String?
  siret          String?
  clientAddress  String?
  clientCity     String?
  clientZip      String?

  // Meta
  isActive       Boolean     @default(true)
  color          String?

  payments       Payment[]
  documents      Document[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
  PARTIAL
}

model Payment {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  month     Int
  year      Int
  expected  Float
  received  Float         @default(0)
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([clientId, month, year])
  @@index([userId])
}

model Scenario {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  icon        String?

  params      Json
  results     Json?

  isPinned    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model MonthlySnapshot {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       Int
  year        Int
  ca          Float
  net         Float
  clientCount Int
  avgTJM      Float
  paymentRate Float
  expenses    Float

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
}

enum HoldingEntityType {
  HOLDING
  OPERATING
  PERSON
}

enum HoldingFlowType {
  DIVIDEND
  MANAGEMENT_FEE
  SALARY
}

enum ProspectStage {
  LEAD
  DEVIS_ENVOYE
  SIGNE
  ACTIF
}

model Prospect {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  estimatedCA   Float
  probability   Int           @default(50)
  stage         ProspectStage @default(LEAD)
  notes         String?
  expectedClose DateTime?
  contactEmail  String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
}

model HoldingStructure {
  id        String          @id @default(uuid())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String          @default("Ma structure holding")
  entities  HoldingEntity[]
  flows     HoldingFlow[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
}

model HoldingEntity {
  id              String            @id @default(uuid())
  structureId     String
  structure       HoldingStructure  @relation(fields: [structureId], references: [id], onDelete: Cascade)
  name            String
  type            HoldingEntityType
  businessStatus  String?
  annualCA        Float             @default(0)
  annualSalary    Float             @default(0)
  managementFees  Float             @default(0)
  positionX       Float             @default(0)
  positionY       Float             @default(0)
  color           String?
  flowsFrom       HoldingFlow[]     @relation("FlowFrom")
  flowsTo         HoldingFlow[]     @relation("FlowTo")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([structureId])
}

model HoldingFlow {
  id            String            @id @default(uuid())
  structureId   String
  structure     HoldingStructure  @relation(fields: [structureId], references: [id], onDelete: Cascade)
  fromEntityId  String
  fromEntity    HoldingEntity     @relation("FlowFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntityId    String
  toEntity      HoldingEntity     @relation("FlowTo", fields: [toEntityId], references: [id], onDelete: Cascade)
  type          HoldingFlowType
  annualAmount  Float             @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([structureId])
}

enum DocumentType {
  DEVIS
  FACTURE
}

enum DocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REFUSED
  PAID
  LATE
  PARTIAL
  CANCELED
}

model Document {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type            DocumentType
  number          String
  status          DocumentStatus  @default(DRAFT)

  issueDate       DateTime        @default(now())
  dueDate         DateTime?
  validUntil      DateTime?
  sentAt          DateTime?
  paidAt          DateTime?

  totalHT         Float           @default(0)
  totalTVA        Float           @default(0)
  totalTTC        Float           @default(0)
  tvaRate         Float           @default(20)

  clientSnapshot  Json?
  issuerSnapshot  Json?

  notes           String?
  sourceDevisId   String?

  items           DocumentItem[]

  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, number])
  @@index([userId])
  @@index([clientId])
  @@index([status])
}

model DocumentItem {
  id          String    @id @default(uuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  description String
  quantity    Float     @default(1)
  unitPrice   Float     @default(0)
  totalHT     Float     @default(0)
  sortOrder   Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([documentId])
}
